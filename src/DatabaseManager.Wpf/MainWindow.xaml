<Window x:Class="DatabaseManager.Wpf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="Database Manager"
        Height="860"
        Width="1360"
        MinHeight="760"
        MinWidth="1200"
        PreviewKeyDown="MainWindow_PreviewKeyDown"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="16" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SchemaAssistantColumn" Width="330" />
                <ColumnDefinition x:Name="SchemaAssistantSplitterColumn" Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SchemaAssistantPanel"
                    Grid.Column="0"
                    MinWidth="260"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Background="{DynamicResource PanelBrush}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Schema Assistant" FontSize="14" FontWeight="SemiBold" />

                    <TabControl x:Name="SchemaAssistantTabControl" Grid.Row="1" Margin="0,10,0,0" SelectionChanged="SchemaAssistantTabControl_SelectionChanged">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TabPanel Grid.Row="0" IsItemsHost="True" Margin="0,0,0,8" />
                                    <ContentPresenter Grid.Row="1"
                                                      ContentSource="SelectedContent"
                                                      Margin="0" />
                                </Grid>
                            </ControlTemplate>
                        </TabControl.Template>
                        <TabItem Header="Databases">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="ActiveDatabaseTextBlock"
                                           FontWeight="SemiBold"
                                           Text="Active database: (none)"
                                           Margin="0,0,0,8" />

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="Refresh" Margin="0,0,8,0" Click="RefreshDatabasesButton_Click" />
                                    <TextBox x:Name="DatabaseSearchTextBox"
                                             Width="190"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Filter databases"
                                             TextChanged="DatabaseSearchTextBox_TextChanged" />
                                </StackPanel>

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <CheckBox x:Name="ShowSystemDatabasesCheckBox"
                                              Content="Show system databases"
                                              Margin="0,0,0,8"
                                              Checked="ShowSystemDatabasesCheckBox_Checked"
                                              Unchecked="ShowSystemDatabasesCheckBox_Unchecked" />

                                    <ListBox x:Name="DatabasesListBox"
                                             Grid.Row="1"
                                             MinHeight="220"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             SelectionChanged="DatabasesListBox_SelectionChanged" />
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Tables">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="Refresh" Margin="0,0,8,0" Click="RefreshSchemaButton_Click" />
                                    <TextBox x:Name="TableSearchTextBox"
                                             Width="190"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Filter tables"
                                             TextChanged="TableSearchTextBox_TextChanged" />
                                </StackPanel>

                                <ListBox x:Name="TablesListBox"
                                         Grid.Row="1"
                                         MinHeight="260"
                                         DisplayMemberPath="FullName"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         SelectionChanged="TablesListBox_SelectionChanged">
                                    <ListBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Generate SELECT" Click="GenerateSelectButton_Click" />
                                            <MenuItem Header="Generate INSERT" Click="GenerateInsertButton_Click" />
                                            <MenuItem Header="Generate UPDATE" Click="GenerateUpdateButton_Click" />
                                            <MenuItem Header="Generate DELETE" Click="GenerateDeleteButton_Click" />
                                            <MenuItem Header="Get Table SQL Schema" Click="GenerateTableSchemaButton_Click" />
                                            <MenuItem Header="Copy Name" Click="CopySelectedObjectNameMenuItem_Click" />
                                        </ContextMenu>
                                    </ListBox.ContextMenu>
                                </ListBox>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Stored Procedures">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="Refresh" Margin="0,0,8,0" Click="RefreshSchemaButton_Click" />
                                    <TextBox x:Name="ProcedureSearchTextBox"
                                             Width="190"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Filter stored procedures"
                                             TextChanged="ProcedureSearchTextBox_TextChanged" />
                                </StackPanel>

                                <ListBox x:Name="StoredProceduresListBox"
                                         Grid.Row="1"
                                         MinHeight="260"
                                         DisplayMemberPath="FullName"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         SelectionChanged="StoredProceduresListBox_SelectionChanged">
                                    <ListBox.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Generate EXEC" Click="GenerateExecButton_Click" />
                                            <MenuItem Header="Open In Runner" Click="OpenRunnerButton_Click" />
                                            <MenuItem Header="Copy Name" Click="CopySelectedObjectNameMenuItem_Click" />
                                        </ContextMenu>
                                    </ListBox.ContextMenu>
                                </ListBox>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Query Templates">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TemplateNameTextBox"
                                             Margin="0,0,8,0"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Template name" />
                                    <Button Grid.Column="1"
                                            Content="Save"
                                            MinWidth="70"
                                            Click="SaveTemplateButton_Click" />
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <ListBox x:Name="TemplatesListBox"
                                             DisplayMemberPath="Name"
                                             MouseDoubleClick="TemplatesListBox_MouseDoubleClick" />

                                    <StackPanel Grid.Row="1"
                                                Margin="0,8,0,0"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button Content="Refresh" MinWidth="70" Margin="0,0,8,0" Click="RefreshTemplatesButton_Click" />
                                        <Button Content="Delete" MinWidth="70" Click="DeleteTemplateButton_Click" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <GridSplitter x:Name="SchemaPanelSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Background="Transparent" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="12"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Background="{DynamicResource SurfaceBrush}">
                    <TabControl x:Name="OutputTabControl">
                        <TabItem Header="Edit Rows">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                                    <Button x:Name="EnterEditModeButton"
                                            Content="Edit Top Rows"
                                            Margin="0,0,8,0"
                                            Click="EnterEditModeButton_Click" />
                                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" Text="Top" />
                                    <TextBox x:Name="EditTopRowsTextBox"
                                             Width="70"
                                             Margin="0,0,8,0"
                                             VerticalContentAlignment="Center"
                                             Text="200"
                                             TextChanged="EditRowsInput_TextChanged" />
                                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" Text="Filter" />
                                    <TextBox x:Name="EditFilterTextBox"
                                             Width="260"
                                             Margin="0,0,8,0"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Optional SQL filter predicate, e.g. Age &gt; 30 AND Country = 'USA'"
                                             TextChanged="EditRowsInput_TextChanged" />
                                    <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" Text="Order By" />
                                    <TextBox x:Name="EditOrderByTextBox"
                                             Width="220"
                                             Margin="0,0,8,0"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Optional ORDER BY expression, e.g. Age DESC, Name ASC"
                                             TextChanged="EditRowsInput_TextChanged" />
                                    <Button x:Name="ApplyEditFilterButton"
                                            Content="Load"
                                            Margin="0,0,8,0"
                                            Click="ApplyEditFilterButton_Click" />
                                    <Button x:Name="SaveRowChangesButton"
                                            Content="Save Changes"
                                            Margin="0,0,8,0"
                                            IsEnabled="False"
                                            Click="SaveRowChangesButton_Click" />
                                    <Button x:Name="DiscardRowChangesButton"
                                            Content="Discard Changes"
                                            IsEnabled="False"
                                            Click="DiscardRowChangesButton_Click" />
                                </WrapPanel>

                                <CheckBox x:Name="EditRowsCustomQueryModeCheckBox"
                                          Grid.Row="1"
                                          Margin="0,10,0,0"
                                          Content="Custom SQL query mode"
                                          VerticalAlignment="Center"
                                          IsChecked="False"
                                          Checked="EditRowsCustomQueryModeCheckBox_Checked"
                                          Unchecked="EditRowsCustomQueryModeCheckBox_Unchecked" />

                                <Grid Grid.Row="2" Margin="0,10,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               FontWeight="SemiBold"
                                               Text="Generated Query (editable)" />

                                    <avalonEdit:TextEditor x:Name="EditQueryTextBox"
                                                           Grid.Row="1"
                                                           Margin="0,6,0,0"
                                                           MinHeight="70"
                                                           FlowDirection="LeftToRight"
                                                           Background="{DynamicResource InputBackgroundBrush}"
                                                           Foreground="{DynamicResource InputForegroundBrush}"
                                                           ShowLineNumbers="True"
                                                           VerticalScrollBarVisibility="Auto"
                                                           HorizontalScrollBarVisibility="Auto"
                                                           TextChanged="EditQueryTextBox_TextChanged"
                                                           PreviewKeyDown="SqlEditorTextBox_PreviewKeyDown"
                                                           FontFamily="Consolas"
                                                           FontSize="12" />
                                </Grid>

                                <TextBlock x:Name="EditRowsSummaryTextBlock"
                                           Grid.Row="3"
                                           Margin="0,10,0,0"
                                           FontWeight="SemiBold"
                                           Text="Edit mode is not active." />

                                <DataGrid x:Name="EditRowsDataGrid"
                                          Grid.Row="3"
                                          Margin="0,10,0,0"
                                          FlowDirection="LeftToRight"
                                          IsReadOnly="True"
                                          AutoGenerateColumns="True"
                                          AutoGeneratingColumn="ResultsDataGrid_AutoGeneratingColumn"
                                          HeadersVisibility="All"
                                          SelectionUnit="CellOrRowHeader"
                                          CanUserAddRows="True"
                                          CanUserDeleteRows="False"
                                          Loaded="DataGrid_Loaded"
                                          LoadingRow="EditRowsDataGrid_LoadingRow"
                                          CurrentCellChanged="EditRowsDataGrid_CurrentCellChanged"
                                          CellEditEnding="EditRowsDataGrid_CellEditEnding"
                                          PreviewMouseRightButtonDown="ResultsDataGrid_PreviewMouseRightButtonDown"
                                          PreviewMouseLeftButtonDown="EditRowsDataGrid_PreviewMouseLeftButtonDown"
                                          PreviewMouseLeftButtonUp="SchemaDataGrid_PreviewMouseLeftButtonUp">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem x:Name="DeleteRowMenuItem"
                                                      Header="Delete Row..."
                                                      IsEnabled="False"
                                                      Click="DeleteRowMenuItem_Click" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="SQL Editor">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Margin="0,0,0,8"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Text="SQL Query" />

                                <avalonEdit:TextEditor x:Name="QueryTextBox"
                                                       Grid.Row="1"
                                                       Padding="10"
                                                       FlowDirection="LeftToRight"
                                                       Background="{DynamicResource InputBackgroundBrush}"
                                                       Foreground="{DynamicResource InputForegroundBrush}"
                                                       ShowLineNumbers="True"
                                                       VerticalScrollBarVisibility="Auto"
                                                       HorizontalScrollBarVisibility="Auto"
                                                       TextChanged="SqlEditorTextBox_TextChanged"
                                                       PreviewKeyDown="SqlEditorTextBox_PreviewKeyDown"
                                                       FontFamily="Consolas"
                                                       FontSize="13" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="Schema">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="SchemaSummaryTextBlock"
                                           FontWeight="SemiBold"
                                           Text="Select a table or stored procedure from Schema Assistant." />

                                <Grid Grid.Row="1" Margin="0,10,0,0">
                                    <Grid x:Name="TableDetailsPanel" Visibility="Visible">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="2*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="SelectedTableTextBlock"
                                                   FontWeight="SemiBold"
                                                   Text="Select a table to inspect columns." />

                                        <DataGrid x:Name="TableColumnsDataGrid"
                                                  Grid.Row="1"
                                                  Margin="0,8,0,8"
                                                  MinHeight="220"
                                                  FlowDirection="LeftToRight"
                                                  IsReadOnly="True"
                                                  AutoGenerateColumns="True"
                                                  HeadersVisibility="All"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  Loaded="DataGrid_Loaded"
                                                  PreviewMouseLeftButtonUp="SchemaDataGrid_PreviewMouseLeftButtonUp" />

                                        <TextBlock Grid.Row="2"
                                                   Margin="0,0,0,6"
                                                   FontWeight="SemiBold"
                                                   Text="Table SQL Definition" />

                                        <TextBox x:Name="TableSqlDefinitionTextBox"
                                                 Grid.Row="3"
                                                 MinHeight="160"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 TextWrapping="NoWrap"
                                                 FontFamily="Consolas"
                                                 FontSize="12" />
                                    </Grid>

                                    <Grid x:Name="ProcedureDetailsPanel" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="2*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="SelectedProcedureTextBlock"
                                                   FontWeight="SemiBold"
                                                   Text="Select a stored procedure to inspect parameters." />

                                        <DataGrid x:Name="ProcedureParametersDataGrid"
                                                  Grid.Row="1"
                                                  Margin="0,8,0,8"
                                                  MinHeight="220"
                                                  FlowDirection="LeftToRight"
                                                  IsReadOnly="True"
                                                  AutoGenerateColumns="True"
                                                  HeadersVisibility="All"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  Loaded="DataGrid_Loaded"
                                                  PreviewMouseLeftButtonUp="SchemaDataGrid_PreviewMouseLeftButtonUp" />

                                        <TextBlock Grid.Row="2"
                                                   Margin="0,0,0,6"
                                                   FontWeight="SemiBold"
                                                   Text="Procedure SQL Definition" />

                                        <TextBox x:Name="ProcedureSqlDefinitionTextBox"
                                                 Grid.Row="3"
                                                 MinHeight="160"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 TextWrapping="NoWrap"
                                                 FontFamily="Consolas"
                                                 FontSize="12" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Results">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ResultsSummaryTextBlock" VerticalAlignment="Center" FontWeight="SemiBold" Text="Results" />
                                    <Button Grid.Column="1"
                                            Margin="8,0,8,0"
                                            Content="Export CSV"
                                            MinWidth="90"
                                            Click="ExportCsvButton_Click" />
                                    <Button Grid.Column="2"
                                            Content="Export Excel"
                                            MinWidth="95"
                                            Click="ExportExcelButton_Click" />
                                </Grid>
                                <ScrollViewer Grid.Row="1"
                                              Margin="0,10,0,0"
                                              FlowDirection="LeftToRight"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="ResultsSectionsPanel"
                                                FlowDirection="LeftToRight" />
                                </ScrollViewer>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Procedure Runner">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="RunnerProcedureTextBlock"
                                           FontWeight="SemiBold"
                                           Text="No procedure selected." />

                                <WrapPanel Grid.Row="1" Margin="0,10,0,10">
                                    <Button Content="Execute Procedure"
                                            Margin="0,0,8,8"
                                            Click="ExecuteProcedureButton_Click" />
                                </WrapPanel>

                                <DataGrid x:Name="RunnerParametersDataGrid"
                                          Grid.Row="2"
                                          FlowDirection="LeftToRight"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="All"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          Loaded="DataGrid_Loaded"
                                          PreviewMouseLeftButtonUp="SchemaDataGrid_PreviewMouseLeftButtonUp">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Parameter"
                                                            Binding="{Binding ParameterName}"
                                                            Width="180"
                                                            IsReadOnly="True" />
                                        <DataGridTextColumn Header="Data Type"
                                                            Binding="{Binding DataType}"
                                                            Width="130"
                                                            IsReadOnly="True" />
                                        <DataGridTextColumn Header="Value"
                                                            Width="*"
                                                            Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                        <DataGridCheckBoxColumn Header="NULL"
                                                                Width="70"
                                                                Binding="{Binding SendAsNull}" />
                                        <DataGridCheckBoxColumn Header="Output"
                                                                Width="80"
                                                                Binding="{Binding IsOutput}"
                                                                IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderBrush}"
                Background="{DynamicResource PanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="210" />
                </Grid.ColumnDefinitions>

                <!-- Text="Server=.;Database=master;Trusted_Connection=True;TrustServerCertificate=True;" -->
                <TextBox x:Name="ConnectionStringTextBox"
                         Grid.Column="0"
                         Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         ToolTip="SQL Server connection string"
                         TextChanged="ConnectionStringTextBox_TextChanged"
                         Text="Data Source=AHMED-TAREK\SQLEXPRESS;Initial Catalog=MVMASTER;User ID=EDCTestUser; Password=123456;Connect Timeout=30;TrustServerCertificate=True;"/>
                <TextBox x:Name="TimeoutTextBox"
                         Grid.Column="1"
                         Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         ToolTip="Timeout in seconds"
                         Text="30" />
                <Button x:Name="ConnectButton"
                        Grid.Column="2"
                        Margin="0,0,8,0"
                    Content="Connect"
                    Click="ConnectButton_Click" />
                <Button x:Name="RunQueryButton"
                        Grid.Column="3"
                        Margin="0,0,8,0"
                        Content="Run"
                        Click="RunQueryButton_Click" />
                <Button x:Name="CancelButton"
                        Grid.Column="4"
                        Margin="0,0,8,0"
                        Content="Cancel"
                        Background="{DynamicResource DangerBrush}"
                        Foreground="{DynamicResource DangerForegroundBrush}"
                        IsEnabled="False"
                        Click="CancelButton_Click" />
                <CheckBox x:Name="SchemaPaneToggleButton"
                      Grid.Column="5"
                      Content="Object Explorer"
                      VerticalAlignment="Center"
                      IsChecked="True"
                      Margin="0,0,8,0"
                      Checked="SchemaPaneToggleButton_Checked"
                      Unchecked="SchemaPaneToggleButton_Unchecked" />
                <CheckBox x:Name="DarkModeCheckBox"
                      Grid.Column="6"
                          Content="Dark mode"
                          VerticalAlignment="Center"
                          IsChecked="True"
                          Checked="DarkModeCheckBox_Checked"
                          Unchecked="DarkModeCheckBox_Unchecked" />
                    <CheckBox x:Name="FullOutputCheckBox"
                        Grid.Column="7"
                        Content="Full output (export/copy)"
                        VerticalAlignment="Center"
                        ToolTip="When enabled, copy and export use non-truncated values." />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                CornerRadius="6"
                Padding="10"
                Background="{DynamicResource StatusBackgroundBrush}">
            <TextBlock x:Name="StatusTextBlock" Foreground="{DynamicResource StatusForegroundBrush}" Text="Ready." />
        </Border>

        <Popup x:Name="SqlSuggestionPopup"
               Placement="Relative"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Background="{DynamicResource SurfaceBrush}"
                    Padding="6"
                    MinWidth="280"
                    MaxWidth="520"
                    MaxHeight="280">
                <ListBox x:Name="SqlSuggestionListBox"
                         BorderThickness="0"
                         Background="Transparent"
                         MouseDoubleClick="SqlSuggestionListBox_MouseDoubleClick" />
            </Border>
        </Popup>
    </Grid>
</Window>
